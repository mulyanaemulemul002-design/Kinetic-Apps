# KineticDAO Environment Variables
# Copy this file to .env and fill in the values

# Deployed contract address on X1T Ecochain (Maculatus Testnet)
VITE_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# X1T Ecochain RPC URL (default: public endpoint)
VITE_RPC_URL=https://maculatus-rpc.x1eco.com

# Chain ID for Maculatus Testnet
VITE_CHAIN_ID=10778
